# Supabase Configuration
# Copy this to .env.local and fill in your values

# Supabase Project URL (from Settings > API)
VITE_SUPABASE_URL=

# Supabase Anon Key (from Settings > API) - safe to expose in frontend
VITE_SUPABASE_ANON_KEY=

# OMDb API Key (optional - for movie searches)
# Get from http://www.omdbapi.com/apikey.aspx
VITE_OMDB_API_KEY=

# Open Library doesn't require an API key for basic searches